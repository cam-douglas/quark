#!/bin/bash
# Pre-push hook that triggers integrated biological pruning when needed
# This hook automatically maintains repository health before pushing to GitHub

REPO_ROOT="$(git rev-parse --show-toplevel)"
PRUNING_SCRIPT="$REPO_ROOT/brain_modules/integrated_pruning_system.py"
LOG_FILE="$REPO_ROOT/logs/git_pruning.log"

# Create logs directory if it doesn't exist
mkdir -p "$(dirname "$LOG_FILE")"

echo "🧠 Pre-push hook: Checking repository health..." | tee -a "$LOG_FILE"

# Check if pruning script exists
if [ ! -f "$PRUNING_SCRIPT" ]; then
    echo "❌ Integrated pruning system not found at $PRUNING_SCRIPT" | tee -a "$LOG_FILE"
    echo "🚨 Push blocked - pruning system required for repository health" | tee -a "$LOG_FILE"
    exit 1
fi

# Check repository size and file count
REPO_SIZE_GB=$(du -s "$REPO_ROOT" | awk '{print $1/1024/1024}')
FILE_COUNT=$(find "$REPO_ROOT" -type f | wc -l)
PYTHON_COUNT=$(find "$REPO_ROOT" -name "*.py" | wc -l)

echo "📊 Repository Status:" | tee -a "$LOG_FILE"
echo "   Size: ${REPO_SIZE_GB} GB" | tee -a "$LOG_FILE"
echo "   Files: $FILE_COUNT" | tee -a "$LOG_FILE"
echo "   Python Files: $PYTHON_COUNT" | tee -a "$LOG_FILE"

# Define thresholds (in GB and file counts)
MAX_SIZE_GB=5.0
MAX_FILES=50000
MAX_PYTHON_FILES=15000

# Check if pruning is needed
NEEDS_PRUNING=false
PRUNING_REASON=""

if (( $(echo "$REPO_SIZE_GB > $MAX_SIZE_GB" | bc -l) )); then
    NEEDS_PRUNING=true
    PRUNING_REASON="Repository size (${REPO_SIZE_GB}GB) exceeds threshold (${MAX_SIZE_GB}GB)"
fi

if [ "$FILE_COUNT" -gt "$MAX_FILES" ]; then
    NEEDS_PRUNING=true
    PRUNING_REASON="File count ($FILE_COUNT) exceeds threshold ($MAX_FILES)"
fi

if [ "$PYTHON_COUNT" -gt "$MAX_PYTHON_FILES" ]; then
    NEEDS_PRUNING=true
    PRUNING_REASON="Python file count ($PYTHON_COUNT) exceeds threshold ($MAX_PYTHON_FILES)"
fi

if [ "$NEEDS_PRUNING" = true ]; then
    echo "🚨 PRUNING REQUIRED: $PRUNING_REASON" | tee -a "$LOG_FILE"
    echo "🧠 Repository health check failed. Pruning required before push." | tee -a "$LOG_FILE"
    echo "" | tee -a "$LOG_FILE"
    echo "🔐 USER ACTION REQUIRED:" | tee -a "$LOG_FILE"
    echo "1. Run: python3 $PRUNING_SCRIPT --workflow" | tee -a "$LOG_FILE"
    echo "2. Review and confirm the pruning plan" | tee -a "$LOG_FILE"
    echo "3. Re-run git push after pruning is complete" | tee -a "$LOG_FILE"
    echo "" | tee -a "$LOG_FILE"
    echo "🚨 Push blocked due to repository health issues" | tee -a "$LOG_FILE"
    exit 1
else
    echo "✅ Repository is healthy. No pruning needed." | tee -a "$LOG_FILE"
fi

echo "🧠 Pre-push health check complete" | tee -a "$LOG_FILE"
